    },
    {
      "id": "v_ar",
      "form": "-ar / -ear / -ejar / -itar / -izar / -ificar / -escer / -ecer",
      "origin": "latim",
      "derived_class": "verbo",
      "value": "sufixos verbalizadores — transformam substantivos e adjetivos em verbos",
      "subtypes": [
        {"form": "-ar", "value": "verbalização geral", "examples": ["cartear (carta)", "telefonar", "namorar", "amar (primitivo)"]},
        {"form": "-ear", "value": "ação repetida ou contínua; verbs de ruído e movimento", "examples": ["guerrear", "folhear", "cochilar → cochilar (-ar)", "tagarelar", "nortear"]},
        {"form": "-ejar", "value": "ação repetida, frequência, aproximação", "examples": ["gotejar", "papejar", "ventanear → ventejar", "clarear → clarejar", "voejar"]},
        {"form": "-izar", "value": "tornar, transformar em, agir como", "examples": ["modernizar", "neutralizar", "digitalizar", "computerizar (anglicismo)", "amenizar"]},
        {"form": "-ificar", "value": "tornar, fazer", "examples": ["pacificar", "justificar", "purificar", "classificar", "terrificar", "intensificar"]},
        {"form": "-escer / -ecer", "value": "processo gradual, início ou desenvolvimento de estado", "examples": ["amadurecer", "florescer", "empalidecer", "enriquecer", "enfraquecer", "envelhecer", "aparecer", "desaparecer"]}
      ]
    },
