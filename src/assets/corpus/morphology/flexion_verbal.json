  "tempos_aspectos_note": {
    "pret_perfeito_simples": "Ação concluída e pontual no passado: 'Escrevi o conto ontem.'",
    "pret_perfeito_composto": "Ação que se repetiu ou tem relevância presente: 'Tenho escrito muito.' (Atenção: no português europeu este tempo tem valor diferente do brasileiro.)",
    "pret_imperfeito": "Ação habitual, contínua ou simultânea no passado: 'Escrevia todas as manhãs.' / 'Enquanto lia, chovia.'",
    "pret_maisq_perf_simples": "Anterioridade em relação a outro fato passado. Na prosa literária, é preferível ao composto: 'Quando chegou, todos já partira.'",
    "futuro_do_preterito": "Exprime: futuro no passado ('Disse que viria'), condicional ('Viria, se pudesse'), polidez ('Poderia me ajudar?') e hipótese ('Seria ele o autor?').",
    "subjuntivo_futuro": "Essencial em orações condicionais e temporais na escrita formal: 'Se vier', 'quando for', 'assim que puder'. No coloquial, tende a ser substituído pelo presente do indicativo."
  }
