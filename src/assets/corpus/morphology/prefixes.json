{
  "version": "1.0",
  "area": "morphology",
  "topic": "prefixes",
  "description": "Catálogo de prefixos do português brasileiro — latinos, gregos e vernáculos — com origem, valor semântico e exemplos.",
  "sources": [
    "Rocha Lima — Gramática Normativa (49ª ed.)",
    "Cunha & Cintra — Nova Gramática (7ª ed.)",
    "Bechara — Moderna Gramática Portuguesa (37ª ed.)"
  ],
  "entries": [
    {"id": "a_privativo", "form": "a- / an-", "origin": "grego", "value": "privação, negação", "allomorphs": ["an- (antes de vogal)"], "examples": ["amoral", "atípico", "anônimo", "anestesia", "anarquia", "apátrida"]},
    {"id": "a_aproximacao", "form": "a-", "origin": "latim", "value": "aproximação, direção, intensidade", "examples": ["aproximar", "amanhecer", "aterrar", "afastar"]},
    {"id": "ante", "form": "ante-", "origin": "latim", "value": "anterioridade no espaço ou no tempo", "examples": ["antessala", "antepassado", "antevéspera", "antever", "anteceder"]},
    {"id": "anti", "form": "anti-", "origin": "grego", "value": "oposição, contrário, contra", "notes": "Leva hífen antes de vogal e 'h': anti-herói, anti-inflamatório. Sem hífen antes de consoante: antídoto, antiético (sem hífen após AO 1990).", "examples": ["antídoto", "anticorpo", "anticlímax", "anti-herói", "antissocial", "antiinflamatório → anti-inflamatório"]},
    {"id": "archi_arqui", "form": "archi- / arqui-", "origin": "grego", "value": "primazia, superioridade, grau máximo", "examples": ["arcebispo", "arquiduque", "arquiinimigo", "arquirrival", "arquimilionário"]},
    {"id": "auto", "form": "auto-", "origin": "grego", "value": "próprio, por si mesmo, de si mesmo", "notes": "Hífen apenas antes de vogal: auto-estrada (EP) / autoestrada (BR após AO 1990).", "examples": ["automóvel", "autocrítica", "autofagia", "autorretrato", "autogestão", "autoimune"]},
    {"id": "bem_bene", "form": "bem- / bene-", "origin": "latim", "value": "qualidade boa, benefício", "examples": ["bem-estar", "benfeitoria", "benévolo", "benevolência", "benefício", "benfeitor"]},
    {"id": "bi_bis", "form": "bi- / bis-", "origin": "latim", "value": "dois, duas vezes, duplicidade", "examples": ["bicicleta", "bilíngue", "bisavô", "bianual", "biscoito", "bípede", "bifocal"]},
    {"id": "circum_circu", "form": "circum- / circu-", "origin": "latim", "value": "ao redor, em volta, em torno", "examples": ["circundar", "circunvizinho", "circunferência", "circuito", "circunstância", "circular"]},
    {"id": "co_com_con_col_cor", "form": "co- / com- / con- / col- / cor-", "origin": "latim", "value": "reunião, associação, junto com", "allomorphs": ["co- (antes de vogal)", "com- (antes de b, p)", "col- (antes de l)", "cor- (antes de r)"], "examples": ["coautor", "compor", "construir", "colaborar", "correr (etimológico)", "concordar", "convidar", "conviver"]},
    {"id": "contra", "form": "contra-", "origin": "latim", "value": "oposição, em sentido contrário", "notes": "Sem hífen em geral: contrapartida, contradição. Com hífen quando o 2º elemento inicia em vogal: contra-atacar, contra-indicação.", "examples": ["contrapor", "contradição", "contrapartida", "contra-atacar", "contrariar", "contrarregra"]},
    {"id": "de_des_di_dis", "form": "de- / des- / di- / dis-", "origin": "latim", "value": "negação, reversão, privação, separação, intensidade (des- pejorat.)", "examples": ["desfazer", "desumano", "desordem", "disparate", "divergir", "dissonância", "deslealdade", "decapitar"]},
    {"id": "ecto", "form": "ecto-", "origin": "grego", "value": "fora, externo", "examples": ["ectoplasma", "ectoparasita"]},
    {"id": "en_em", "form": "en- / em-", "origin": "grego/latim", "value": "dentro, movimento para dentro, transformação (forma verbal parassintetética)", "allomorphs": ["em- antes de b, p, m"], "examples": ["enraizar", "embarcar", "empobrecer", "enriquecer", "emagrecer", "embelezar", "enredar"]},
    {"id": "endo", "form": "endo-", "origin": "grego", "value": "dentro, interno", "examples": ["endoscopia", "endógeno", "endocrino", "endoparasita"]},
    {"id": "entre", "form": "entre-", "origin": "latim", "value": "posição intermediária, reciprocidade, ação incompleta", "examples": ["entreabrir", "entrelinha", "entrevista", "entretanto", "entreter", "entrelaçar"]},
    {"id": "epi", "form": "epi-", "origin": "grego", "value": "sobre, em cima, além, após", "examples": ["epígrafe", "epidemia", "epitáfio", "epílogo", "epiderme", "epicentro", "episódio"]},
    {"id": "ex", "form": "ex-", "origin": "latim", "value": "que foi e não é mais (estado anterior), fora de, saída", "notes": "Sempre com hífen para indicar estado anterior: ex-marido, ex-presidente, ex-aluno.", "examples": ["ex-presidente", "ex-marido", "exportar", "excluir", "expirar", "exilar", "expatriar"]},
    {"id": "extra", "form": "extra-", "origin": "latim", "value": "fora de, além de, em grau extremo", "examples": ["extraordinário", "extraoficial", "extracurricular", "extravagante", "extrassensorial"]},
    {"id": "geo", "form": "geo-", "origin": "grego", "value": "terra", "examples": ["geografia", "geologia", "geopolítica", "geométrico", "geossíncrono"]},
    {"id": "hemi", "form": "hemi-", "origin": "grego", "value": "metade", "examples": ["hemisfério", "hemiplegia", "hemiciclo"]},
    {"id": "hetero", "form": "hetero-", "origin": "grego", "value": "diferente, diverso, outro", "examples": ["heterogêneo", "heterossexual", "heterodoxo", "heterônimo", "heteróclito"]},
    {"id": "hiper", "form": "hiper-", "origin": "grego", "value": "excesso, acima do normal, muito intenso", "examples": ["hiperativo", "hipertensão", "hipérbole", "hipermercado", "hiperinflação", "hipertext"]},
    {"id": "hipo", "form": "hipo-", "origin": "grego", "value": "abaixo do normal, inferior, insuficiente", "examples": ["hipotensão", "hipotético", "hipodérmico", "hipoglicemia", "hipopótamo (água + cabalo)"]},
    {"id": "homo", "form": "homo-", "origin": "grego", "value": "igual, mesmo, semelhante", "examples": ["homogêneo", "homônimo", "homólogo", "homosexual", "homógrafo", "homófono"]},
    {"id": "i_ir_il_im_in", "form": "i- / ir- / il- / im- / in-", "origin": "latim", "value": "negação, privação (antes de adjetivos e substantivos)", "allomorphs": ["im- antes de b, p", "il- antes de l", "ir- antes de r", "i- antes de gn, s+consoante"], "examples": ["impossível", "ilegal", "irracional", "imoral", "infeliz", "ignorante", "isento (i+s)"]},
    {"id": "infra", "form": "infra-", "origin": "latim", "value": "abaixo de, inferior, estrutura base", "examples": ["infraestrutura", "infravermelho", "infrasom", "infrarrealismo"]},
    {"id": "inter", "form": "inter-", "origin": "latim", "value": "entre, no meio de, reciprocidade", "examples": ["internacional", "interdisciplinar", "intercâmbio", "interlíngua", "interativo", "interpor"]},
    {"id": "intra", "form": "intra-", "origin": "latim", "value": "dentro de, interior", "examples": ["intramuscular", "intranet", "intravenoso", "intramuros", "intrafamiliar"]},
    {"id": "intro", "form": "intro-", "origin": "latim", "value": "para dentro, movimento interior", "examples": ["introduzir", "introvertido", "introspecção", "introito"]},
    {"id": "iso", "form": "iso-", "origin": "grego", "value": "igual, mesmo, equivalente", "examples": ["isósceles", "isótopo", "isométrico", "isobar", "isolado (via fr.)"]},
    {"id": "justa_juxt", "form": "justa- / juxt-", "origin": "latim", "value": "ao lado de, próximo", "examples": ["justapor", "justaposição"]},
    {"id": "macro", "form": "macro-", "origin": "grego", "value": "grande, em grande escala, longo", "examples": ["macroeconomia", "macrocosmo", "macroestrutura", "macrofotografia"]},
    {"id": "mal_male", "form": "mal- / male-", "origin": "latim", "value": "qualidade ruim, ação negativa, erro", "examples": ["malfeitor", "maldizer", "malcriar", "maltratar", "malcuidado", "malevolência"]},
    {"id": "mega", "form": "mega-", "origin": "grego", "value": "muito grande, um milhão (SI)", "examples": ["megafone", "megaestrutura", "megabyte", "megalópolis", "megalômano"]},
    {"id": "meta", "form": "meta-", "origin": "grego", "value": "depois, além de, mudança, reflexividade (sobre si mesmo)", "examples": ["metacognição", "metáfora", "metafísica", "metalinguagem", "metadados", "metatexto"]},
    {"id": "micro", "form": "micro-", "origin": "grego", "value": "pequeno, milionésima parte (SI)", "examples": ["microorganismo", "microcosmo", "microfone", "microchip", "microscopio", "microempresa"]},
    {"id": "mini", "form": "mini-", "origin": "latim", "value": "pequeno, reduzido, inferior ao padrão", "examples": ["minissaia", "minibar", "minirroteiro", "miniempresa"]},
    {"id": "mono", "form": "mono-", "origin": "grego", "value": "um só, único, sozinho", "examples": ["monolingue", "monólogo", "monotonia", "monopolio", "monogamia", "monossílabo"]},
    {"id": "multi", "form": "multi-", "origin": "latim", "value": "muitos, múltiplo, grande quantidade", "examples": ["multilíngue", "multidisciplinar", "multitarefa", "multiétnico", "multiplicar"]},
    {"id": "neo", "form": "neo-", "origin": "grego", "value": "novo, recente, renovação", "examples": ["neologismo", "neoclássico", "neonatal", "neoliberal", "neonazismo", "neorrealismo"]},
    {"id": "ob", "form": "ob- / o- / of- / op-", "origin": "latim", "value": "diante de, contra, em direção a, em oposição", "allomorphs": ["o- antes de m, v", "of- antes de f", "op- antes de p"], "examples": ["objeção", "obstáculo", "oferecer", "oportunidade", "opor"]},
    {"id": "over", "form": "over-", "origin": "inglês", "value": "acima, excessivo", "notes": "Internacionalismo crescente no português contemporâneo.", "examples": ["overdose", "overload"]},
    {"id": "pan", "form": "pan- / panto-", "origin": "grego", "value": "tudo, totalidade, universal", "examples": ["pan-americano", "panorama", "panteísmo", "pandemônio", "pandemia", "pantógrafo"]},
    {"id": "para", "form": "para-", "origin": "grego", "value": "ao lado de, além de, semelhança, proteção", "examples": ["paralelismo", "paradoxo", "paramilitar", "paramédico", "paraquedas", "paranormal"]},
    {"id": "peri", "form": "peri-", "origin": "grego", "value": "ao redor, em torno", "examples": ["perímetro", "periferia", "peristilo", "periélio", "periscópio"]},
    {"id": "poli", "form": "poli-", "origin": "grego", "value": "muitos, múltiplo, diversidade", "examples": ["polissílabo", "polissemia", "políglota", "politeísmo", "polivalente", "poliedro"]},
    {"id": "pos_post", "form": "pós- / post-", "origin": "latim", "value": "depois, posterior no tempo ou espaço", "notes": "Pós- sempre com hífen antes de vogal, h ou em compostos em que o 2º elemento começa por maiúscula: pós-graduação, pós-moderno, pós-AO.", "examples": ["pós-graduação", "pós-moderno", "pós-guerra", "postponer (→ pospor)", "pós-colonial"]},
    {"id": "pre", "form": "pré-", "origin": "latim", "value": "antes, anterioridade no tempo ou espaço", "notes": "Sempre com acento e hífen antes de vogal ou h: pré-escola, pré-histórico.", "examples": ["pré-vestibular", "prehistoric", "pré-natal", "precursor", "pré-julgamento", "premissa"]},
    {"id": "pro", "form": "pró- / pro-", "origin": "latim/grego", "value": "a favor de, em frente, avanço, substituição", "notes": "Pró- (tônico, a favor): pró-ativo. Pro- (átono, em lugar de): procurador.", "examples": ["pró-ativo", "pró-labore", "procurador", "promover", "profilaxia", "programar"]},
    {"id": "proto", "form": "proto-", "origin": "grego", "value": "primeiro, original, anterior a", "examples": ["protótipo", "protocolo", "protolíngua", "protestantismo (etimologia disputada)", "protohistória"]},
    {"id": "pseudo", "form": "pseudo-", "origin": "grego", "value": "falso, aparente, imitação enganosa", "examples": ["pseudônimo", "pseudociência", "pseudointelectual", "pseudo-herói"]},
    {"id": "re", "form": "re-", "origin": "latim", "value": "repetição, retorno, intensidade, novo", "examples": ["rever", "refazer", "reescrever", "reaprender", "relembrar", "reafirmar", "renovar"]},
    {"id": "retro", "form": "retro-", "origin": "latim", "value": "para trás, em sentido contrário", "examples": ["retroagir", "retroalimentação", "retroprojetor", "retrospectiva", "retrógrado"]},
    {"id": "semi", "form": "semi-", "origin": "latim", "value": "metade, parcialmente, quase", "examples": ["semiárido", "semivogal", "semicírculo", "semifinalista", "semiaberto", "semiconductor"]},
    {"id": "sobre_supra", "form": "sobre- / supra-", "origin": "latim", "value": "acima, em grau superior, além", "examples": ["sobrehumano", "sobrenome", "sobrepor", "supranacional", "supracitado", "sobressalente"]},
    {"id": "sub_so_sus", "form": "sub- / so- / sus- / sus-", "origin": "latim", "value": "abaixo, inferioridade, insuficiência, sotto", "allomorphs": ["so- antes de l, p (assimilação antiga): soltar, suster", "sus- em: suspender"], "examples": ["subdesenvolvido", "sublinhar", "subtítulo", "subproduto", "sucumbir", "soterrar", "sustentar", "suspender"]},
    {"id": "super", "form": "super-", "origin": "latim", "value": "acima, em grau elevado, excesso", "examples": ["supermercado", "superpopulação", "superficial", "superlativo", "superestimar", "superestrutura"]},
    {"id": "tele", "form": "tele-", "origin": "grego", "value": "distância, longe, transmissão à distância", "examples": ["televisão", "telefone", "telecomunicação", "telepatia", "telemedicina", "telerradiologia"]},
    {"id": "trans_tres_tra", "form": "trans- / tres- / tra-", "origin": "latim", "value": "através de, além de, mudança, transformação", "allomorphs": ["tra- em: trabalhar (etimologia disputada)", "tres- em: treslouco (arcaico)"], "examples": ["transatlântico", "transformar", "transmitir", "translúcido", "transdisciplinar", "treslouco"]},
    {"id": "tri", "form": "tri-", "origin": "latim/grego", "value": "três, triplo", "examples": ["triângulo", "trissílabo", "tricampeão", "tricolor", "tríptico", "tridimensional"]},
    {"id": "ultra", "form": "ultra-", "origin": "latim", "value": "além de, extremo, excessivo", "examples": ["ultrassom", "ultrapassar", "ultravioleta", "ultradireita", "ultraconservador", "ultrassofisticado"]},
    {"id": "uni", "form": "uni-", "origin": "latim", "value": "um, único, singular", "examples": ["uniforme", "unidade", "unilateral", "unicórnio", "unificação", "unissex"]}
  ]
}
