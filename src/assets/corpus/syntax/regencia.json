    {
      "id": "crase",
      "label": "Crase — síntese aplicada à regência",
      "definition": "A crase marca a fusão da preposição 'a' com o artigo 'a' (ou com pronomes demonstrativos 'aquele/a/es/as', 'aquilo'). Só ocorre diante de palavra feminina que admite artigo 'a'.",
      "rules": [
        {
          "id": "crase_regra_geral",
          "label": "Regra geral",
          "rule": "Há crase quando o verbo/nome exige preposição 'a' E o complemento é feminino com artigo.",
          "test": "Substituir o feminino por masculino equivalente. Se aparecer 'ao', há crase no feminino.",
          "examples": [
            {"test": "Fui ao mercado → Fui à feira. ✓ (ao → à)", "note": "ir exige 'a'; 'feira' admite artigo"},
            {"test": "Refiro-me ao presidente → Refiro-me à presidenta. ✓"}
          ]
        },
        {
          "id": "crase_proibida",
          "label": "Crase proibida",
          "cases": [
            {"case": "Antes de substantivo masculino", "example": "Andou a pé. (sem crase)"},
            {"case": "Antes de verbo", "example": "Começou a correr. (sem crase)"},
            {"case": "Antes de pronome pessoal", "example": "Disse a ela. (sem crase)"},
            {"case": "Antes de pronome de tratamento (exceto 'senhora')", "example": "A você. / A Vossa Senhoria."},
            {"case": "Antes de 'uma'", "example": "Chegou a uma conclusão. (sem crase)"},
            {"case": "Antes de nome de cidade sem artigo", "example": "Viajei a Paris. / Viajei ao Rio. (Rio tem artigo)"}
          ]
        },
        {
          "id": "crase_facultativa",
          "label": "Crase facultativa",
          "cases": [
            {"case": "Antes de pronome possessivo feminino", "example": "Refiro-me a sua mãe. / Refiro-me à sua mãe."},
            {"case": "Antes de nome de mulher célebre", "example": "Dedico a Clarice / à Clarice."}
          ]
        },
        {
          "id": "crase_demonstrativos",
          "label": "Crase com demonstrativos",
          "rule": "Preposição 'a' + 'aquele/a/es/as/aquilo' → 'àquele/àquela/àqueles/àquelas/àquilo'.",
          "examples": ["Refiro-me àquele episódio.", "Comparável àquilo que vivemos.", "Semelhante àquelas situações."]
        }
      ]
    }
  ]
}
